<Window x:Class="TickNager.Ventanas.CrearUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TickNager.Ventanas"
        mc:Ignorable="d"
        Title="CrearUsuarioWindow" Height="500" Width="800">
    <Grid Background="#0C0D21">
        <!--2 columnas, 1 para la foto, y la otra para la entrada de datos-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <Grid Grid.Column="0">
            <Image Source="/Imagenes/Iconos/perfil_usuario.png" Height="300"/>
        </Grid>
        
        <Grid Grid.Column="1">
            <Border>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="110"/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="Nombre de usuario:" Foreground="White" Margin="10 20 0 0" TextAlignment="Left"/>
                        <TextBox Background="#171A45" Height="20px" Width="160" HorizontalAlignment="Left" Margin="10 0 0 0"/>
                        <TextBlock Text="Apellido de usuario:" Foreground="White" Margin="0 20 100 0" TextAlignment="Right"/>
                        <TextBox Background="#171A45" Height="20px" Width="160" HorizontalAlignment="Right" Margin="0 0 45 0"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <TextBlock Text="Rol:" Foreground="White" Margin="10px 10px 0 0"/>
                        <!--Desplegable para elegir el rol-->
                        <ComboBox Name="roles" Height="30px" Width="118" SelectedIndex="0" HorizontalAlignment="Left" Margin="10 0 0 0">
                            <ComboBoxItem Content="Selecciona un rol"/>
                            <ComboBoxItem Content="Técnico"/>
                            <ComboBoxItem Content="Usuario"/>
                        </ComboBox>
                        <TextBlock Text="Departamento:" Foreground="White" Margin="0 10 125 0" TextAlignment="Right"/>
                        <TextBox Background="#171A45" Height="20" Width="160" HorizontalAlignment="Right" Margin="0 0 45 0"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <TextBlock  Text="Correo eletrónico" Foreground="White" Margin="10 0 0 0"/>
                        <TextBox Background="#171A45" Height="20" Width="355" HorizontalAlignment="Left" Margin="10 0 0 0"/>
                    </Grid>

                    <Grid Grid.Row="3">
                        <TextBlock  Text="Contraseña:" Foreground="White" Margin="10 0 0 0"/>
                        <PasswordBox Background="#171A45" Height="20" Width="355" HorizontalAlignment="Left" Margin="10 0 0 0"/>
                    </Grid>

                    <Grid Grid.Row="4">
                        <TextBlock  Text="Confirmar contraseña:" Foreground="White" Margin="10 0 0 0"/>
                        <PasswordBox Background="#171A45" Height="20" Width="355" HorizontalAlignment="Left" Margin="10 0 0 0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
