<Window x:Class="TickNager.Ventanas.AvisoCampoVacioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TickNager.Ventanas"
        mc:Ignorable="d"
        Title="Aviso" Height="110" Width="300">
    <Grid Background="White">
        <TextBlock Text="No se permite dejar el campo vacío" Foreground="Black" TextAlignment="Center" Margin="0 20 0 0"/>
        <Button Height="25" Width="60" Content="Cerrar" Margin="0 30 0 0" Click="btnAvisoCampoVacio_Click"/>
    </Grid>
</Window>