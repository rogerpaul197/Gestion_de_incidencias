<Window x:Class="TickNager.Principal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TickNager"
        mc:Ignorable="d"
        Title="Principal" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/> <!--Cabecera-->
            <RowDefinition/> <!--Estructura debajo de la cabecera-->
        </Grid.RowDefinitions>
        
        <!--Cabecera-->
        <Grid Grid.Row="0" Background="#0C0D21">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/> <!--Logotipo del programa-->
                <ColumnDefinition Width="350"/> <!--El buscador-->
                <ColumnDefinition/> <!--Notificaciones, logo/nombre de usuario-->
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBlock Text="Ticknager" Foreground="White" VerticalAlignment="Center"/>
            </Grid>
            <Grid Grid.Column="1">
                
                <TextBlock Text="Buscador" Foreground="#0C0D21" VerticalAlignment="Center" HorizontalAlignment="Center" Width="300" Background="#171A45"/>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/> <!--Notificaciones-->
                    <ColumnDefinition/> <!--ícono del usuario-->
                    <ColumnDefinition Width="95"/> <!--Nombre del administrador-->
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBlock Text="Notificaciones" Foreground="White" VerticalAlignment="Center"/>
                </Grid>

                <Grid Grid.Column="1">
                    <Image Source="/Imagenes/Iconos/perfil.png" Width="20" HorizontalAlignment="Right"/>
                </Grid>

                <Grid Grid.Column="2">
                    <TextBlock Text="Administrador" Width="90" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Grid>
        
        <!--Estructura debajo de la cabecera, se dividirá en 2 columnas, la izquierda el menú 
        y la derecha lo que devuelve al hacer clic en una opción del menú-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#171A45">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Text="Dashboard" Width="140" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="1">
                    <TextBlock Text="Incidencias" Width="140" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="2">
                    <TextBlock Text="Gestión de usuarios" Width="140" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="3">
                    <TextBlock Text="Equipos" Width="140" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="4">
                    <TextBlock Text="Categorías" Width="140" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="5">
                    <TextBlock Text="Ajustes" Width="140" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
            </Grid>
            <Grid Grid.Column="1" Background="#0C0D21">
            </Grid>

        </Grid>
    </Grid>
</Window>
