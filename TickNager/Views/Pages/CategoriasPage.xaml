<Page x:Class="TickNager.Views.Pages.CategoriasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TickNager.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CategoriasPage">

    <Grid Background="#0C0D21">
        <StackPanel Margin="30">

            <TextBlock Text="Categorías"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,25"/>

            <TextBlock Text="Lista de categorías disponibles"
                       FontSize="16"
                       Foreground="White"
                       Margin="0,0,0,15"/>

            <ListBox Width="300"
                     Height="180"
                     Background="#171A45"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="10">
                <ListBoxItem Content="Hardware"/>
                <ListBoxItem Content="Software"/>
                <ListBoxItem Content="Red"/>
                <ListBoxItem Content="Impresoras"/>
                <ListBoxItem Content="Cuentas de usuario"/>
            </ListBox>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <TextBox Width="200"
                         Height="30"
                         Margin="0,0,10,0"/>

                <Button Content="Agregar"
                        Width="100"
                        Height="30"
                        Background="#3A8DFF"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
