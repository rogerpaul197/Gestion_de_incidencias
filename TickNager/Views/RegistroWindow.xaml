<Window x:Class="TickNager.Views.RegistroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TickNager"
        mc:Ignorable="d"
        Title="RegistroWindow" Height="500" Width="400">
    <Grid Background="#151f2d">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock Text="¡Bienvenido a TickNager!" Foreground="White" FontSize="25px" TextAlignment="Center" Margin="0 20px 0 0"/>
        </Grid>
        <Grid Grid.Row="1">
            <TextBlock Text="Introduce tu nombre" Foreground="White" Margin="40px 0 0 0"/>
            <TextBox Height="30px" Width="150px" HorizontalAlignment="Left" Margin="40px 0 0 0"/>
            <TextBlock Text="Introduce tu Apellido" Foreground="White" TextAlignment="Right" Margin="0 0 78px 0"/>
            <TextBox Height="30px" Width="150px" HorizontalAlignment="Right" Margin="0 0 40px 0"/>
        </Grid>
        <Grid Grid.Row="2">
            <TextBlock Text="Introduce tu número" Foreground="White" Margin="40px 0 0 0"/>
            <TextBox Height="30px" Width="320px"/>
        </Grid>
        <Grid Grid.Row="3">
            <TextBlock Text="Introduce tu Correo" Foreground="White" Margin="40px 0 0 0"/>
            <TextBox Height="30px" Width="320px"/>
        </Grid>
        <Grid Grid.Row="4">
            <TextBlock Text="Introduce tu contraseña" Foreground="White" Margin="40px 0 0 0"/>
            <PasswordBox Name="txtContrasena" Height="30px" Width="320px"/>
        </Grid>
        <Grid Grid.Row="5">
            <TextBlock Text="Confirma tu contraseña" Foreground="White" Margin="40px 0 0 0"/>
            <PasswordBox Name="txtContrasenaConfirmacion" Height="30px" Width="320px"/>
        </Grid>
        <Grid Grid.Row="6">
            <Button Height="30px" Width="80px" Content="Registrarse" Click="btnRegistro_Click"/>
        </Grid>
    </Grid>
</Window>
